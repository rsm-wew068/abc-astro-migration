---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { breadcrumbSchema } from '../../lib/schema';
import { SITE } from '../../lib/site';
import { SERVICE_DETAILS } from '../../lib/services';

export function getStaticPaths() {
  return SERVICE_DETAILS.map((s) => ({ params: { slug: s.slug }, props: { s } }));
}

const { s } = Astro.props;
---
<BaseLayout
  title={s.metaTitle}
  description={s.metaDescription}
  schemaNodes={[
    breadcrumbSchema([
      { name: 'Home', url: '/' },
      { name: 'Service', url: '/service' },
      { name: s.title, url: `/service/${s.slug}` },
    ]),
    {
      '@type': 'Service',
      name: s.title,
      description: s.metaDescription,
      url: `${SITE.url}/service/${s.slug}`,
      provider: { '@id': `${SITE.url}/#organization` },
      areaServed: SITE.areaServed.map((name) => ({ '@type': 'Place', name })),
    },
  ]}
>
  <PageHero bg={s.hero} eyebrow="Service" title={s.title} minHeight="60vh" />

  <section class="section tagline">
    <div class="container">
      <a href="/service" class="back">&larr; All services</a>
      <h2>{s.tagline}</h2>
    </div>
  </section>

  <section class="feat">
    {s.features.map((f, i) => (
      <div class:list={['feat__row', { 'feat__row--reverse': i % 2 === 1 }]}>
        {f.img ? (
          <Image src={f.img} alt={f.title} class="feat__img" widths={[500, 800]} sizes="(max-width: 900px) 100vw, 50vw" />
        ) : (
          <div class="feat__num"><span>{String(i + 1).padStart(2, '0')}</span></div>
        )}
        <div class="feat__text">
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      </div>
    ))}
  </section>

  <section class="section section--dark cta">
    <div class="container cta__inner">
      <h2>Ready to start your project?</h2>
      <a href="/contact" class="btn">Start Building With Us</a>
    </div>
  </section>
</BaseLayout>

<style>
  .tagline { text-align: center; padding-bottom: 0; }
  .back { font-family: var(--font-ui); font-size: 14px; color: var(--color-body); display: inline-block; margin-bottom: 20px; }
  .back:hover { color: var(--color-off-black); text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 3px; }
  .tagline h2 { max-width: 820px; margin-inline: auto; }

  .feat { padding: 40px 0 80px; }
  .feat__row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center;
    max-width: var(--container-max); margin: 0 auto; padding: 40px var(--container-pad);
  }
  .feat__row--reverse .feat__img,
  .feat__row--reverse .feat__num { order: 2; }
  .feat__img { width: 100%; border-radius: var(--radius); object-fit: cover; aspect-ratio: 3 / 2; }
  .feat__num {
    aspect-ratio: 3 / 2; border-radius: var(--radius); background: var(--color-off-white);
    display: flex; align-items: center; justify-content: center;
  }
  .feat__num span { font-family: var(--font-heading); font-size: 96px; color: var(--color-accent); }
  .feat__text h3 { margin-bottom: 12px; }
  .feat__text p { font-size: 18px; color: var(--color-body); }

  .cta__inner { text-align: center; }
  .cta__inner h2 { margin-bottom: 24px; }

  @media (max-width: 900px) {
    .feat__row { grid-template-columns: 1fr; gap: 20px; }
    .feat__row--reverse .feat__img,
    .feat__row--reverse .feat__num { order: 0; }
  }
</style>
