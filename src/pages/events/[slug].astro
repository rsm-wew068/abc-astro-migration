---
import SmartImage from '../../components/SmartImage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../../lib/schema';
import { SITE } from '../../lib/site';
import { ALL_EVENTS, formatDate, type EventItem } from '../../lib/events';
import { eventImage } from '../../lib/eventImages';

export function getStaticPaths() {
  return ALL_EVENTS.map((e) => ({ params: { slug: e.slug }, props: { e } }));
}

const { e } = Astro.props as { e: EventItem };
const hero = eventImage(e.thumb);
const galleryImgs = e.gallery.map((g) => eventImage(g)).filter(Boolean) as string[];

const eventSchema = {
  '@type': 'Event',
  name: e.title,
  startDate: e.date,
  eventStatus: 'https://schema.org/EventScheduled',
  ...(hero ? { image: hero } : {}),
  description: e.description,
  organizer: { '@id': `${SITE.url}/#organization` },
  location: {
    '@type': 'Place',
    name: 'Bay Area',
    address: { '@type': 'PostalAddress', addressRegion: 'CA', addressCountry: 'US' },
  },
};
---
<BaseLayout
  title={`${e.title} | American Built Cabinets`}
  description={e.description}
  image={hero}
  schemaNodes={[
    breadcrumbSchema([
      { name: 'Home', url: '/' },
      { name: 'Events', url: '/events' },
      { name: e.title, url: `/events/${e.slug}` },
    ]),
    eventSchema,
  ]}
>
  <header class="ehero">
    {hero && <SmartImage src={hero} alt="" class="ehero__bg" widths={[960, 1440, 1920]} sizes="100vw" loading="eager" />}
    <div class="ehero__overlay"></div>
    <div class="container ehero__inner">
      <p class="ehero__eyebrow">{e.category || 'Event'}</p>
      <h1>{e.title}</h1>
      <p class="ehero__date">{formatDate(e.date)}</p>
    </div>
  </header>

  <article class="ev container">
    <a href="/events" class="back">&larr; All events</a>
    <p class="ev__lede">{e.description}</p>
    {e.content && <div class="ev__body"><p>{e.content}</p></div>}

    {galleryImgs.length > 0 && (
      <section class="ev__gallery">
        {galleryImgs.map((img, i) => (
          <SmartImage src={img} alt={`${e.title} - photo ${i + 1}`} widths={[640, 960]} sizes="(max-width: 640px) 100vw, 50vw" loading="lazy" />
        ))}
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .ehero { position: relative; min-height: 56vh; display: flex; align-items: center; overflow: hidden; background: var(--color-off-black); }
  .ehero :global(.ehero__bg) { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .ehero__overlay { position: absolute; inset: 0; background: rgba(20,20,22,0.55); }
  .ehero__inner { position: relative; text-align: center; color: #fff; }
  .ehero__eyebrow { font-family: var(--font-ui); text-transform: uppercase; letter-spacing: 0.2em; font-size: 13px; color: var(--color-accent); margin-bottom: 16px; }
  .ehero h1 { color: #fff; max-width: 900px; margin: 0 auto 16px; }
  .ehero__date { font-family: var(--font-ui); color: rgba(255,255,255,0.9); }

  .ev { max-width: 820px; padding-top: 40px; padding-bottom: 24px; }
  .back { font-family: var(--font-ui); font-size: 14px; color: var(--color-body); display: inline-block; margin-bottom: 24px; }
  .back:hover { color: var(--color-accent); }
  .ev__lede { font-size: 21px; color: var(--color-off-black); margin-bottom: 24px; }
  .ev__body p { color: var(--color-body); }
  .ev__gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin: 32px 0 80px; }
  .ev__gallery :global(img) { width: 100%; border-radius: var(--radius); object-fit: cover; aspect-ratio: 4 / 3; }
  @media (max-width: 640px) { .ev__gallery { grid-template-columns: 1fr; } }
</style>
