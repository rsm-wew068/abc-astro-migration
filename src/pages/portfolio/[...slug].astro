---
import { getCollection, render } from 'astro:content';
import SmartImage from '../../components/SmartImage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { creativeWorkSchema, breadcrumbSchema } from '../../lib/schema';
import { imageUrl } from '../../lib/img';
import { SITE } from '../../lib/site';

export async function getStaticPaths() {
  const items = await getCollection('portfolio');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { data } = item;
const { Content } = await render(item);

const heroBg = data.thumbnail ?? data.photos[0];

const schemaNodes = [
  creativeWorkSchema({
    title: data.title,
    description: data.summary,
    slug: item.id,
    images: [
      ...(data.thumbnail ? [imageUrl(data.thumbnail)!] : []),
      ...data.photos.map((p) => imageUrl(p)!),
    ],
    category: data.category,
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Portfolio', url: '/portfolio' },
    { name: data.title, url: `/portfolio/${item.id}` },
  ]),
];
---
<BaseLayout
  title={`${data.title} | ${SITE.name}`}
  description={data.summary}
  image={imageUrl(data.thumbnail)}
  schemaNodes={schemaNodes}
>
  <header class="phero">
    {heroBg && (
      <SmartImage src={heroBg} alt="" class="phero__bg" loading="eager" widths={[960, 1440, 1920]} sizes="100vw" />
    )}
    <div class="phero__overlay"></div>
    <div class="container phero__inner">
      <h1>{data.title}</h1>
    </div>
  </header>

  <article class="work container">
    <a href="/portfolio" class="back">&larr; Back</a>
    {data.category && <p class="eyebrow center">{data.category}</p>}
    <div class="work__body">
      <Content />
    </div>
  </article>

  {data.photos.length > 0 && (
    <section class="gallery container">
      {data.photos.map((photo, i) => (
        <SmartImage
          src={photo}
          alt={`${data.title} - cabinetry installation photo ${i + 1}`}
          class="gallery__photo"
          widths={[640, 960, 1280]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      ))}
    </section>
  )}
</BaseLayout>

<style>
  .center { text-align: center; }
  .phero { position: relative; min-height: 60vh; display: flex; align-items: center; overflow: hidden; background: var(--color-off-black); }
  .phero :global(.phero__bg) { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .phero__overlay { position: absolute; inset: 0; background: rgba(20,20,22,0.5); }
  .phero__inner { position: relative; text-align: center; }
  .phero h1 { color: #fff; max-width: 900px; margin-inline: auto; }

  .work { max-width: 820px; padding-top: 40px; padding-bottom: 24px; text-align: center; }
  .back { font-family: var(--font-ui); font-size: 15px; color: var(--color-body); display: inline-block; margin-bottom: 24px; }
  .back:hover { color: var(--color-off-black); text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 3px; }
  .work__body { text-align: left; max-width: 720px; margin-inline: auto; }
  .work__body :global(p) { color: var(--color-body); }

  .gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; padding-bottom: 80px; }
  .gallery :global(.gallery__photo) { width: 100%; border-radius: var(--radius); object-fit: cover; }
  @media (max-width: 768px) { .gallery { grid-template-columns: 1fr; } }
</style>
