---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SmartImage from '../../components/SmartImage.astro';
import { articleSchema, faqSchema, breadcrumbSchema } from '../../lib/schema';
import { imageUrl } from '../../lib/img';
import { SITE } from '../../lib/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, all: posts },
  }));
}

const { post, all } = Astro.props;
const { data } = post;
const { Content } = await render(post);

// Up to 3 other posts for the "Explore Related Blogs" strip.
const related = all
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const heroBg = data.coverImage ?? data.heroImage;
const ogImage = imageUrl(data.coverImage ?? data.heroImage);

const schemaNodes = [
  articleSchema({
    title: data.title,
    description: data.intro,
    slug: post.id,
    image: ogImage,
    publishDate: data.publishDate,
    updatedDate: data.updatedDate,
    category: data.category,
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Blog', url: '/blog' },
    { name: data.title, url: `/blog/${post.id}` },
  ]),
];
if (data.faq.length) {
  schemaNodes.push(faqSchema(data.faq.map((f) => ({ question: f.q, answer: f.a }))));
}
---
<BaseLayout
  title={`${data.title} | ${SITE.name}`}
  description={data.intro}
  image={ogImage}
  schemaNodes={schemaNodes}
>
  <!-- Full-bleed hero with the title overlaid, matching the live design -->
  <header class="bhero">
    {heroBg && (
      <SmartImage src={heroBg} alt="" class="bhero__bg" loading="eager" widths={[960, 1440, 1920]} sizes="100vw" />
    )}
    <div class="bhero__overlay"></div>
    <div class="container bhero__inner">
      <h1>{data.title}</h1>
    </div>
  </header>

  <article class="post container">
    <a href="/blog" class="back">&larr; Back</a>

    <div class="post__body">
      <Content />
    </div>

    {data.faq.length > 0 && (
      <section class="post__faq">
        <h2>FAQ</h2>
        {data.faq.map((f, i) => (
          <div class="faq-item">
            <p class="faq-q">Q{i + 1}: {f.q}</p>
            <p class="faq-a">A{i + 1}: {f.a}</p>
          </div>
        ))}
      </section>
    )}
  </article>

  {related.length > 0 && (
    <section class="section section--muted related">
      <div class="container">
        <p class="eyebrow center">Dive Deeper Into Real Estate Insights</p>
        <h2 class="center">Explore Related Blogs</h2>
        <div class="related__grid">
          {related.map((p) => (
            <a href={`/blog/${p.id}`} class="rcard">
              {p.data.coverImage && (
                <SmartImage src={p.data.coverImage} alt={p.data.title} class="rcard__img" widths={[320, 480]} sizes="(max-width: 768px) 100vw, 360px" />
              )}
              <div class="rcard__body">
                <span class="rcard__date">{p.data.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                <h3>{p.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .center { text-align: center; }
  /* HERO */
  .bhero { position: relative; min-height: 60vh; display: flex; align-items: center; overflow: hidden; background: var(--color-off-black); }
  .bhero :global(.bhero__bg) { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .bhero__overlay { position: absolute; inset: 0; background: rgba(20,20,22,0.5); }
  .bhero__inner { position: relative; text-align: center; }
  .bhero h1 { color: #fff; max-width: 900px; margin-inline: auto; }

  /* BODY */
  .post { max-width: 820px; padding-top: 40px; padding-bottom: 24px; }
  .back { font-family: var(--font-ui); font-size: 15px; color: var(--color-body); display: inline-block; margin-bottom: 32px; }
  .back:hover { color: var(--color-off-black); text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 3px; }
  .post__body :global(h2) { font-family: var(--font-heading); font-weight: 400; margin: 1.4em 0 0.5em; }
  .post__body :global(p) { color: var(--color-body); }

  /* FAQ */
  .post__faq { margin-top: 48px; }
  .post__faq h2 { font-family: var(--font-heading); font-weight: 400; margin-bottom: 20px; }
  .faq-item { margin-bottom: 20px; }
  .faq-q { font-weight: 600; color: var(--color-off-black); margin-bottom: 4px; }
  .faq-a { color: var(--color-body); margin: 0; }

  /* RELATED */
  .related__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 40px; }
  .rcard { display: block; background: #fff; border-radius: var(--radius); overflow: hidden; color: var(--color-body); border: 1px solid rgba(0,0,0,0.06); transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .rcard:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.08); }
  .rcard :global(.rcard__img) { width: 100%; aspect-ratio: 3 / 2; object-fit: cover; }
  .rcard__body { padding: 20px; }
  .rcard__date { font-family: var(--font-ui); font-size: 13px; color: var(--color-accent); }
  .rcard__body h3 { font-size: 19px; margin: 8px 0 0; font-family: var(--font-body); font-weight: 700; color: var(--color-off-black); }
  @media (max-width: 768px) { .related__grid { grid-template-columns: 1fr; } }
</style>
