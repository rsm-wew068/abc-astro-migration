---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import EventCard from '../components/EventCard.astro';
import { breadcrumbSchema } from '../lib/schema';
import { UPCOMING } from '../lib/events';
import heroBg from '../assets/home/hero-2.png';
---
<BaseLayout
  title="Upcoming Events | American Built Cabinets"
  description="Upcoming events, trade shows, and sponsorships from American Built Cabinets across the Bay Area."
  schemaNodes={[breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Events', url: '/events' },
    { name: 'Upcoming Events', url: '/upcoming-events' },
  ])]}
>
  <PageHero bg={heroBg} eyebrow="Mark Your Calendar" title="Upcoming Events" minHeight="54vh" />

  <section class="section">
    <div class="container">
      {UPCOMING.length > 0 ? (
        <div class="evgrid">
          {UPCOMING.map((e) => <EventCard event={e} />)}
        </div>
      ) : (
        <div class="empty">
          <h2>No upcoming events right now.</h2>
          <p>Check back soon, or browse our <a href="/past-events">past events</a>.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .evgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .empty { text-align: center; max-width: 520px; margin: 0 auto; padding: 40px 0; }
  .empty h2 { margin-bottom: 12px; }
  @media (max-width: 900px) { .evgrid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .evgrid { grid-template-columns: 1fr; } }
</style>
