---
import { SITE } from '../lib/site';

const pages = [
  { label: 'Home', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Service', href: '/service' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Contact Us', href: '/contact' },
];
const company = [
  { label: 'About Us', href: '/about' },
  { label: 'Trade Program', href: '/trade-program' },
  { label: 'Contact', href: '/contact' },
];
const info = [
  { label: 'Warranty', href: '/warranty' },
  { label: 'Blog', href: '/blog' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Privacy', href: '/privacy' },
];
---
<footer class="footer">
  <div class="container">
    <img src="/images/logo-wordmark.png" alt={SITE.name} class="footer__logo" width="200" height="55" />
  </div>

  <div class="container footer__grid">
    <div class="footer__col footer__col--contact">
      <p class="footer__heading">Contact Information</p>
      <ul class="footer__contact">
        <li>
          <span class="footer__ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg></span>
          <a href={`tel:${SITE.telephone}`}>{SITE.telephoneDisplay}</a>
        </li>
        <li>
          <span class="footer__ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg></span>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </li>
        <li>
          <span class="footer__ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg></span>
          <address>{SITE.address.street}<br />{SITE.address.city}, {SITE.address.region}</address>
        </li>
      </ul>
      <div class="footer__social">
        <a href={SITE.sameAs[0]} rel="me" aria-label="Instagram" class="footer__social-ico">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 01-1.38-.9 3.7 3.7 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23C3.21 15.58 3.2 15.2 3.2 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.21 8.8 2.2 12 2.2zm0 1.8c-3.15 0-3.5.01-4.75.07-.9.04-1.38.19-1.7.32-.43.16-.73.36-1.06.68-.32.33-.52.63-.68 1.06-.13.32-.28.8-.32 1.7C3.21 8.5 3.2 8.85 3.2 12s.01 3.5.07 4.75c.04.9.19 1.38.32 1.7.16.43.36.73.68 1.06.33.32.63.52 1.06.68.32.13.8.28 1.7.32 1.25.06 1.6.07 4.75.07s3.5-.01 4.75-.07c.9-.04 1.38-.19 1.7-.32.43-.16.73-.36 1.06-.68.32-.33.52-.63.68-1.06.13-.32.28-.8.32-1.7.06-1.25.07-1.6.07-4.75s-.01-3.5-.07-4.75c-.04-.9-.19-1.38-.32-1.7a2.85 2.85 0 00-.68-1.06 2.85 2.85 0 00-1.06-.68c-.32-.13-.8-.28-1.7-.32C15.5 4.01 15.15 4 12 4zm0 3.06A4.94 4.94 0 1012 17a4.94 4.94 0 000-9.88zm0 8.14A3.2 3.2 0 1112 8.8a3.2 3.2 0 010 6.4zm6.3-8.34a1.15 1.15 0 11-1.15-1.15 1.15 1.15 0 011.15 1.15z"/></svg>
        </a>
        <a href={SITE.sameAs[1]} rel="me" aria-label="LinkedIn" class="footer__social-ico">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 11-.02 5 2.5 2.5 0 01.02-5zM3 8.98h4V21H3V8.98zM9.5 8.98h3.8v1.64h.05c.53-1 1.82-2.06 3.75-2.06 4.01 0 4.75 2.64 4.75 6.07V21h-4v-5.38c0-1.28-.02-2.93-1.78-2.93-1.79 0-2.06 1.4-2.06 2.84V21h-4V8.98z"/></svg>
        </a>
      </div>
    </div>

    <div class="footer__col">
      <p class="footer__heading">Pages</p>
      {pages.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
    <div class="footer__col">
      <p class="footer__heading">Company</p>
      {company.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
    <div class="footer__col">
      <p class="footer__heading">Information</p>
      {info.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>
  </div>

  <div class="container footer__certs">
    <img src="/images/certs/asid.png" alt="American Society of Interior Designers" loading="lazy" />
    <img src="/images/certs/kcma.png" alt="KCMA Certified Cabinet" loading="lazy" />
    <img src="/images/certs/nkba.png" alt="National Kitchen & Bath Association" loading="lazy" />
    <img src="/images/certs/nari.png" alt="National Association of the Remodeling Industry" loading="lazy" />
  </div>

  <div class="container footer__bottom">
    <p>© {new Date().getFullYear()} {SITE.shortName}. All Rights Reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-snow);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding: 64px 0 32px;
    font-family: var(--font-body);
    font-size: 16px;
  }
  .footer__logo { width: 200px; height: auto; display: block; margin-bottom: 44px; }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1fr;
    gap: 32px;
    align-items: start;
  }
  .footer__heading {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 16px;
    color: var(--color-off-black);
    margin: 0 0 20px;
  }
  .footer__col { display: flex; flex-direction: column; gap: 14px; }
  .footer__col a { color: var(--color-body); }
  .footer__col a:hover {
    color: var(--color-off-black);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }
  .footer__contact { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 16px; }
  .footer__contact li { display: flex; align-items: center; gap: 14px; }
  .footer__ico { flex-shrink: 0; color: var(--color-off-black); line-height: 0; }
  .footer__ico svg { width: 22px; height: 22px; display: block; }
  .footer__contact a { color: var(--color-body); }
  .footer__contact address { font-style: normal; color: var(--color-body); }
  .footer__social { display: flex; gap: 16px; margin-top: 22px; }
  .footer__social-ico { color: var(--color-off-black); line-height: 0; transition: opacity 0.2s ease; }
  .footer__social-ico svg { width: 24px; height: 24px; display: block; }
  .footer__social-ico:hover { opacity: 0.6; }
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    color: var(--color-body);
  }
  .footer__certs { display: flex; align-items: center; gap: 40px; margin-top: 48px; flex-wrap: wrap; }
  .footer__certs img { height: 70px; width: auto; object-fit: contain; }
  .footer__bottom p { margin: 0; }
  @media (max-width: 768px) {
    .footer__grid { grid-template-columns: 1fr 1fr; }
    .footer__bottom { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
