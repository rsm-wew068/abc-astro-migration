---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * Renders either a local imported asset (ImageMetadata) or a remote
 * object-storage URL (string) through Astro's image optimizer.
 * Remote URLs use `inferSize` and require the host to be allow-listed in
 * astro.config `image.domains` / `remotePatterns`.
 */
interface Props {
  src: ImageMetadata | string;
  alt: string;
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: 'eager' | 'lazy';
}

const {
  src,
  alt,
  widths = [640, 960, 1280],
  sizes = '100vw',
  class: className,
  loading = 'lazy',
} = Astro.props;

const isRemote = typeof src === 'string';
---
{isRemote ? (
  <Image src={src as string} alt={alt} inferSize widths={widths} sizes={sizes} class={className} loading={loading} />
) : (
  <Image src={src as ImageMetadata} alt={alt} widths={widths} sizes={sizes} class={className} loading={loading} />
)}
