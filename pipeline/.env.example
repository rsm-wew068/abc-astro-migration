# --- Claude (text) --- set ONE, or use `ant auth login` instead
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- OpenAI (gpt-image-1) ---
OPENAI_API_KEY=sk-xxxxxxxx

# --- Image object storage (S3-compatible: Cloudflare R2 / MinIO-on-Railway / S3) ---
# When these are set, generated images upload here instead of being written to git.
# Cloudflare R2 example:
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=xxxxxxxx
S3_SECRET_ACCESS_KEY=xxxxxxxx
S3_BUCKET=abcabinet-images
# Public/CDN base the site links to (R2 custom domain, or Cloudflare Images URL):
S3_PUBLIC_BASE_URL=https://cdn.abcabinet.us
